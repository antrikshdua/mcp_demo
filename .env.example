# ── Server ───────────────────────────────────────────────────────────────────
ENV=development
FASTMCP_HOST=127.0.0.1
FASTMCP_PORT=8000
FASTMCP_MASK_ERROR_DETAILS=false        # Set true in production

# ── Agent / LLM ──────────────────────────────────────────────────────────────
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=local-model

# ── BigQuery — Required ───────────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_LOCATION=US                    # Common values: US, EU, us-central1, europe-west4

# ── BigQuery — Auth ───────────────────────────────────────────────────────────
# Leave unset to use Application Default Credentials (recommended)
# Run: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── BigQuery — Startup Validation ────────────────────────────────────────────
BIGQUERY_CHECK_AUTH_ON_STARTUP=true     # Validate credentials + query perms on startup

# ── BigQuery — Access Control ────────────────────────────────────────────────
BIGQUERY_ALLOWED_DATASETS=              # Comma-separated allowlist; empty = all datasets

# ── BigQuery — Billing & Safety ──────────────────────────────────────────────
BIGQUERY_MAX_BYTES_BILLED=109951162777  # Per-query billing cap (~$0.50 USD at $5/TiB)
BIGQUERY_TIMEOUT=30                     # Query timeout in seconds

# ── BigQuery — Result Limits ─────────────────────────────────────────────────
BIGQUERY_MAX_RESULTS=20                 # Max rows returned by bq_run_query
BIGQUERY_LIST_MAX_RESULTS=500           # Max results for bq_list_datasets / bq_list_tables
BIGQUERY_LIST_MAX_RESULTS_DETAILED=25   # Max results when detailed=true

# ── BigQuery — Table Analysis ────────────────────────────────────────────────
BIGQUERY_SAMPLE_ROWS=3                  # Sample rows returned by bq_get_table
BIGQUERY_SAMPLE_ROWS_FOR_STATS=500      # Rows sampled for column fill-rate calculation

# ── BigQuery — Vector Search (optional) ──────────────────────────────────────
BIGQUERY_VECTOR_SEARCH_ENABLED=false
BIGQUERY_EMBEDDING_MODEL=               # Required if enabled: project.dataset.model
BIGQUERY_EMBEDDING_TABLES=             # Optional: comma-separated dataset.table pairs (skips auto-discovery)
BIGQUERY_EMBEDDING_COLUMN_CONTAINS=embedding
BIGQUERY_DISTANCE_TYPE=COSINE           # COSINE | EUCLIDEAN | DOT_PRODUCT

# ── BigQuery — Logging ────────────────────────────────────────────────────────
BIGQUERY_LOG_FILE=                      # Optional: /var/log/mcp-bigquery.log (empty = stdout only)
